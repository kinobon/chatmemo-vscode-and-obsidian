{
  "name": "chatmemo",
  "displayName": "ChatMemo",
  "description": "Slack-like chat memo editor for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "chatmemo.editor",
        "displayName": "ChatMemo Editor",
        "selector": [
          {
            "filenamePattern": "*.chat.md"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "chatmemo.openAsText",
        "title": "ChatMemo: Open as Plain Text"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "chatmemo.openAsText",
          "when": "resourceFilename =~ /\\.chat\\.md$/"
        }
      ],
      "commandPalette": [
        {
          "command": "chatmemo.openAsText",
          "when": "resourceFilename =~ /\\.chat\\.md$/"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "tsc -watch -p ./",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
